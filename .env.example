# ─── LLM Configuration ────────────────────────────────────────────────────────
# Get your free Groq API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── Internet Research ─────────────────────────────────────────────────────────
# Get your free Serper API key at: https://serper.dev (2500 free searches/month)
# If not set, the agent falls back to a built-in curated phone dataset
SERPER_API_KEY=your_serper_api_key_here

# ─── Avalanche Blockchain ─────────────────────────────────────────────────────
# Avalanche C-Chain Mainnet RPC
AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc

# Your wallet private key (0x-prefixed) - needs tiny AVAX for gas (~0.001 AVAX)
# Leave empty to skip on-chain logging
PRIVATE_KEY=

# ─── x402 Configuration ───────────────────────────────────────────────────────
# Enable x402 automatic payment handling (true/false)
X402_ENABLED=true

# ─── Agent Configuration ──────────────────────────────────────────────────────
# LLM model to use (groq models)
GROQ_MODEL=llama-3.3-70b-versatile

# Maximum candidates to fetch before ranking
MAX_CANDIDATES=30

# Enable debug logging
DEBUG=false
